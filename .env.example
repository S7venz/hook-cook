# Hook & Cook — template de variables d'environnement
#
# Démarrage en deux commandes (zéro config requise) :
#   cp .env.example .env
#   docker compose up -d
#
# Les valeurs par défaut ci-dessous sont conçues pour un clone-and-run :
# Postgres en local, mails loggés à la console, Stripe désactivé (mode mock
# où les commandes / permis / inscriptions concours sont validés directement,
# sans paiement réel). Le seed démo est activé : 10 utilisateurs, 18
# commandes, permis, inscriptions, etc.
#
# **Avant une vraie mise en production**, renouvelle TOUS les secrets :
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"

# --- Database ----------------------------------------------------------------
POSTGRES_DB=hookcook
POSTGRES_USER=hookcook
POSTGRES_PASSWORD=hookcook

# --- Sécurité ----------------------------------------------------------------
# Clé de signature JWT (HS512, 64 octets recommandés).
# La valeur ci-dessous est OK pour le dev / la démo. En prod, regénère-la.
JWT_SECRET=4GmSIoObaVoKiIed6hvKjQJ8fASOpLVNdUGM-YLit4bZoB_vRD5ufkYNT9RoH-nhKk6NPJ1JwGAeLklLPZ55MA

# Compte admin créé au premier boot (si email pas encore en base).
# Connexion immédiate sur /connexion → bouton Admin en haut à droite.
ADMIN_EMAIL=admin@hookcook.fr
ADMIN_PASSWORD=admin1234

# --- Email (SMTP) ------------------------------------------------------------
# Vide = mails loggés en console (parfait pour la démo).
# Renseigne pour envoyer de vrais mails (Gmail + app password, Mailgun, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@hookcook.fr

# --- Seed de démonstration ---------------------------------------------------
# true = injecte au premier boot : 10 utilisateurs (mot de passe demo1234),
# 18 commandes sur 6 mois, 6 permis (mix de statuts), 10 inscriptions
# concours, 8 avis clients, 6 prises carnet, 7 favoris. Idempotent (skippe
# si déjà injecté). À mettre à false en prod.
HC_SEED_DEMO=true

# --- Paiement Stripe ---------------------------------------------------------
# Vide = MODE MOCK : commandes/permis/concours marqués payés directement,
# sans appel à Stripe. Utile pour la démo, la CI, ou un dev sans clé.
#
# Pour activer le vrai flux Stripe, récupère tes clés de test sur
# https://dashboard.stripe.com/test/apikeys puis remplis les 3 lignes.
# Le webhook secret est affiché par :
#   stripe listen --forward-to localhost:8080/api/payments/webhook
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=eur

# --- Frontend ----------------------------------------------------------------
# URL exposée au navigateur pour contacter l'API (passée à Vite à la build).
VITE_API_URL=http://localhost:8080
# Clé publique Stripe exposée au navigateur (= STRIPE_PUBLIC_KEY).
# Vide en mode mock.
VITE_STRIPE_PUBLIC_KEY=
