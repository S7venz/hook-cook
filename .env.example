# Hook & Cook — template de variables d'environnement
#
# Pour démarrer :
#   cp .env.example .env
#   # puis remplace les valeurs CHANGE_ME par de vraies valeurs fortes
#
# Génération rapide de secrets forts :
#   python -c "import secrets; print(secrets.token_urlsafe(64))"

# --- Database ---
POSTGRES_DB=hookcook
POSTGRES_USER=hookcook
POSTGRES_PASSWORD=CHANGE_ME_long_random_db_password

# --- Security ---
# JWT signing key (HS512 — 64 octets min recommandé)
JWT_SECRET=CHANGE_ME_long_random_64_bytes_base64

# Compte admin seed (créé au premier boot si absent)
ADMIN_EMAIL=admin@hookcook.fr
ADMIN_PASSWORD=CHANGE_ME_admin_password

# --- Email (SMTP) ---
# Laisser vide = mails loggés dans la console (dev).
# Renseigner pour envoyer de vrais mails (ex: Gmail + app password, Mailgun, SendGrid).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@hookcook.fr

# --- Seed de démonstration ---
# À true pour injecter au premier boot : 10 utilisateurs fictifs
# (mot de passe demo1234), 18 commandes sur 6 mois, 6 permis (mix
# de statuts), 10 inscriptions concours, 8 avis clients, 6 prises
# carnet, 7 favoris. Idempotent (skippe si déjà injecté).
# À laisser vide ou false en prod.
HC_SEED_DEMO=

# --- Paiement Stripe ---
# Mode test : récupère les clés sur https://dashboard.stripe.com/test/apikeys
# Si STRIPE_SECRET_KEY est vide, le backend bascule en "mock" (commande
# directement marquée payée — utile pour CI ou démo sans clé).
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# Webhook signing secret affiché par `stripe listen --forward-to localhost:8080/api/payments/webhook`
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Devise utilisée par les PaymentIntent (par défaut: eur)
STRIPE_CURRENCY=eur

# --- Frontend ---
# URL exposée au navigateur pour contacter l'API (build-time Vite)
VITE_API_URL=http://localhost:8080
# Clé publique Stripe exposée au navigateur (même valeur que STRIPE_PUBLIC_KEY)
VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
